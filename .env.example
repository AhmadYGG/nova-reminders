# ============================================
# Nova Reminders - Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Database
# SQLite (development): file:./dev.db
# MySQL (production):   mysql://nova_user:<password>@mysql:3306/nova_reminders
DATABASE_URL="file:./dev.db"

# Auth Secrets - generate with: openssl rand -hex 32
JWT_SECRET=""
NEXTAUTH_SECRET=""

# VAPID Keys for Web Push Notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@yourdomain.com"

# Cron Secret - generate with: openssl rand -hex 32
CRON_SECRET=""

# Redis
REDIS_URL="redis://redis:6379"

# MySQL (production only)
# Use simple alphanumeric passwords (openssl rand -hex 32)
MYSQL_ROOT_PASSWORD=""
MYSQL_USER="nova_user"
MYSQL_PASSWORD=""
MYSQL_DATABASE="nova_reminders"
